generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model BlogPost {
  id           String            @id @default(cuid())
  category     String
  title        String            @db.Text
  excerpt      String            @db.Text
  content      String            @db.LongText
  author       String
  clickCount   Int               @default(0)
  likeCount    Int               @default(0)
  dislikeCount Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  postImage         String?           @db.LongText
  imageFocus        String?           @db.VarChar(32)
  imageFocusHero    String?           @db.VarChar(32)
  imageFocusGround  String?           @db.VarChar(32)
  authorImage       String?           @db.LongText
  authorUserId String?
  uploaderName String?
  isHidden     Boolean           @default(false)
  User         User?             @relation(fields: [authorUserId], references: [id])
  comments     ArticleComment[]
  reactions    ArticleReaction[]

  @@index([authorUserId], map: "BlogPost_authorUserId_fkey")
}

model ArticleComment {
  id         String   @id @default(cuid())
  blogPostId String
  name       String
  email      String
  comment    String   @db.Text
  createdAt  DateTime @default(now())
  BlogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@index([blogPostId])
}

model ArticleReaction {
  id         String   @id @default(cuid())
  blogPostId String
  visitorId  String
  reaction   String
  createdAt  DateTime @default(now())
  BlogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, visitorId])
  @@index([blogPostId])
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         Role       @default(CONTRIBUTOR)
  active       Boolean    @default(true)
  permissions  String?    @db.LongText
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  BlogPost     BlogPost[]
}

model AbhiyanEvent {
  id        String   @id
  title     String
  date      String
  time      String
  location  String
  details   String   @db.LongText
  imageUrl  String?  @db.LongText
  createdAt DateTime @default(now())
}

model Otp {
  id        String   @id
  email     String
  code      String
  purpose   String   @default("register")
  attempts  Int      @default(0)
  expiresAt DateTime
  verified  Boolean  @default(false)

  @@index([email])
}

model Resource {
  id        String   @id @default(cuid())
  title     String
  type      String
  url       String?
  fileData  String?  @db.LongText
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  phone       String?
  consentedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([email])
}

enum Role {
  MASTER_ADMIN
  ADMIN
  CONTRIBUTOR
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
}

